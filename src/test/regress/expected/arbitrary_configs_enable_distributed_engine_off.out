\set VERBOSITY terse
DELETE FROM col_a WHERE grp = 20;
ERROR:  UPDATE and CTID scans not supported for ColumnarScan
\set VERBOSITY default
TRUNCATE col_b;
INSERT INTO col_b VALUES (40, 60, 'reloaded');
SELECT count(*) FROM col_b;
 count
